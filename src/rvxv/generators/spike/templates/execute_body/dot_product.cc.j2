{# ---------------------------------------------------------------------------
   dot_product / outer_product execute body

   Generates a proper vector iteration loop that reads `group_size` narrow
   source elements per destination element and accumulates them.

   For DOT_PRODUCT: acc += a[i*G+g] * b[i*G+g]    (element-wise within group)
   For OUTER_PRODUCT: dest[r*vl+c] = a[r] * b[c]   (N x N matrix)

   Uses real Spike vector API: insn.rd(), insn.rs1(), insn.rs2() for register
   numbers, P.VU.elt<T>() for element access, proper vstart/vl/mask handling.
--------------------------------------------------------------------------- #}
{
  const reg_t vl = P.VU.vl->read();
  const reg_t vstart_val = P.VU.vstart->read();
  const bool masked = insn.v_vm() == 0;
  const reg_t rd_num = insn.rd();
  const reg_t rs2_num = insn.rs2();
  const reg_t rs1_num = insn.rs1();

{% if is_outer_product %}
  // Outer product: {{ sources[0].name }} (column) x {{ sources[1].name }} (row)
  // Output is vl x vl matrix stored linearly in destination register group
  const reg_t num_outputs = vl * vl;
  for (reg_t i = vstart_val; i < num_outputs; ++i) {
    const reg_t row = i / vl;
    const reg_t col = i % vl;
    if (masked && !(P.VU.elt<uint8_t>(0, i / 8) & (1 << (i % 8))))
      continue;
{% if dest.needs_conv %}
    float acc = {{ dest.to_f32 }}(P.VU.elt<{{ dest.c_type }}>(rd_num, i));
{% elif dest.is_float %}
    {{ dest.c_type }} acc = P.VU.elt<{{ dest.c_type }}>(rd_num, i);
{% else %}
    {{ dest.c_type }} acc = P.VU.elt<{{ dest.c_type }}>(rd_num, i);
{% endif %}
{% if sources[0].needs_conv %}
    float a = {{ sources[0].to_f32 }}(P.VU.elt<{{ sources[0].c_type }}>(rs2_num, row));
    float b = {{ sources[1].to_f32 }}(P.VU.elt<{{ sources[1].c_type }}>(rs1_num, col));
{% elif sources[0].is_float %}
    {{ sources[0].c_type }} a_raw = P.VU.elt<{{ sources[0].c_type }}>(rs2_num, row);
    {{ sources[1].c_type }} b_raw = P.VU.elt<{{ sources[1].c_type }}>(rs1_num, col);
    float a = (float)a_raw;
    float b = (float)b_raw;
{% else %}
    {{ dest.c_type }} a = ({{ dest.c_type }})P.VU.elt<{{ sources[0].c_type }}>(rs2_num, row);
    {{ dest.c_type }} b = ({{ dest.c_type }})P.VU.elt<{{ sources[1].c_type }}>(rs1_num, col);
{% endif %}
    acc += a * b;
{% if saturation == "signed" and not dest.needs_conv and not dest.is_float %}
    // Signed saturation (NOTE: for correctness, acc should use int64_t;
    // this path is less common for outer products but handled for completeness)
    if (acc > INT{{ dest.width_bits }}_MAX) acc = INT{{ dest.width_bits }}_MAX;
    if (acc < INT{{ dest.width_bits }}_MIN) acc = INT{{ dest.width_bits }}_MIN;
{% elif saturation == "unsigned" and not dest.needs_conv and not dest.is_float %}
    if (acc > UINT{{ dest.width_bits }}_MAX) acc = UINT{{ dest.width_bits }}_MAX;
    if (acc < 0) acc = 0;
{% endif %}
{% if dest.needs_conv %}
    P.VU.elt<{{ dest.c_type }}>(rd_num, i, true) = {{ dest.from_f32 }}(acc);
{% else %}
    P.VU.elt<{{ dest.c_type }}>(rd_num, i, true) = acc;
{% endif %}
  }
{% else %}
  // {{ group_size }}-way dot product: {{ sources[0].name }} x {{ sources[1].name }} -> {{ dest.name }}
  // vl counts source-width elements; each output consumes {{ group_size }} inputs.
  const reg_t num_outputs = vl / {{ group_size }};
  for (reg_t i = vstart_val; i < num_outputs; ++i) {
    if (masked && !(P.VU.elt<uint8_t>(0, i / 8) & (1 << (i % 8))))
      continue;

{% if accumulate %}
{% if dest.needs_conv %}
    float acc = {{ dest.to_f32 }}(P.VU.elt<{{ dest.c_type }}>(rd_num, i));
{% elif dest.is_float %}
    {{ dest.c_type }} acc = P.VU.elt<{{ dest.c_type }}>(rd_num, i);
{% elif saturation != "none" %}
    int64_t acc = (int64_t)P.VU.elt<{{ dest.c_type }}>(rd_num, i);
{% else %}
    {{ dest.c_type }} acc = P.VU.elt<{{ dest.c_type }}>(rd_num, i);
{% endif %}
{% else %}
{% if dest.is_float and not dest.needs_conv %}
    {{ dest.c_type }} acc = 0.0;
{% elif dest.needs_conv %}
    float acc = 0.0f;
{% elif saturation != "none" %}
    int64_t acc = 0;
{% else %}
    {{ dest.c_type }} acc = 0;
{% endif %}
{% endif %}
    for (int g = 0; g < {{ group_size }}; g++) {
{% if sources[0].needs_conv %}
      float a = {{ sources[0].to_f32 }}(P.VU.elt<{{ sources[0].c_type }}>(rs2_num, i * {{ group_size }} + g));
      float b = {{ sources[1].to_f32 }}(P.VU.elt<{{ sources[1].c_type }}>(rs1_num, i * {{ group_size }} + g));
      acc += a * b;
{% elif sources[0].is_float %}
      {{ sources[0].c_type }} a_raw = P.VU.elt<{{ sources[0].c_type }}>(rs2_num, i * {{ group_size }} + g);
      {{ sources[1].c_type }} b_raw = P.VU.elt<{{ sources[1].c_type }}>(rs1_num, i * {{ group_size }} + g);
      acc += ({{ dest.c_type }})a_raw * ({{ dest.c_type }})b_raw;
{% elif sources[0].is_subbyte %}
      // Sub-byte element: {{ sources[0].width_bits }}-bit value in {{ sources[0].sew_bits }}-bit container.
      // Sign-extend from {{ sources[0].width_bits }} bits.
      {
        const int W = {{ sources[0].width_bits }};
        const uint8_t lo_mask = (1u << W) - 1;
        uint8_t raw_a = P.VU.elt<uint8_t>(rs2_num, i * {{ group_size }} + g) & lo_mask;
        uint8_t raw_b = P.VU.elt<uint8_t>(rs1_num, i * {{ group_size }} + g) & lo_mask;
        const int32_t sign_bit = 1 << (W - 1);
        int32_t a = (int32_t)(raw_a ^ sign_bit) - sign_bit;
        int32_t b = (int32_t)(raw_b ^ sign_bit) - sign_bit;
{% if saturation != "none" %}
        acc += (int64_t)a * (int64_t)b;
{% else %}
        acc += ({{ dest.c_type }})a * ({{ dest.c_type }})b;
{% endif %}
      }
{% else %}
      {{ sources[0].c_type }} a = P.VU.elt<{{ sources[0].c_type }}>(rs2_num, i * {{ group_size }} + g);
      {{ sources[1].c_type }} b = P.VU.elt<{{ sources[1].c_type }}>(rs1_num, i * {{ group_size }} + g);
{% if saturation != "none" %}
      acc += (int64_t)a * (int64_t)b;
{% else %}
      acc += ({{ dest.c_type }})a * ({{ dest.c_type }})b;
{% endif %}
{% endif %}
    }
{% if saturation == "signed" and not dest.needs_conv and not dest.is_float %}
    if (acc > INT{{ dest.width_bits }}_MAX) acc = INT{{ dest.width_bits }}_MAX;
    if (acc < INT{{ dest.width_bits }}_MIN) acc = INT{{ dest.width_bits }}_MIN;
{% elif saturation == "unsigned" and not dest.needs_conv and not dest.is_float %}
    if (acc > (int64_t)UINT{{ dest.width_bits }}_MAX) acc = (int64_t)UINT{{ dest.width_bits }}_MAX;
    if (acc < 0) acc = 0;
{% endif %}
{% if dest.needs_conv %}
    P.VU.elt<{{ dest.c_type }}>(rd_num, i, true) = {{ dest.from_f32 }}(acc);
{% elif saturation != "none" and not dest.is_float %}
    P.VU.elt<{{ dest.c_type }}>(rd_num, i, true) = ({{ dest.c_type }})acc;
{% else %}
    P.VU.elt<{{ dest.c_type }}>(rd_num, i, true) = acc;
{% endif %}
  }
{% endif %}
  P.VU.vstart->write(0);
}
