int main(int argc, char** argv) {
    Verilated::commandArgs(argc, argv);
    auto tb = new Vtb_{{ name }};

    int cycle = 0;
    int pass_count = 0;
    int fail_count = 0;

    // Open RVFI trace CSV
    std::ofstream rvfi_csv("rvfi_trace_{{ name }}.csv");
    rvfi_csv << "cycle,rvfi_valid,rvfi_trap,rvfi_insn,rvfi_rd_addr,rvfi_rd_wdata\n";

    auto test_vectors = get_test_vectors();
    int num_tests = test_vectors.size();

    printf("=== RVXV Verilator Testbench: {{ name }} ===\n");
    printf("VLEN=%d, %d test vectors\n\n", VLEN, num_tests);

    // ---- Reset ----
    tb->rst_n = 0;
    tb->valid_in = 0;
    tb->insn = 0;
    tb->vm = 1;
    tb->vl = 0;
    tb->vstart_in = 0;
    memset(tb->vs1_data.data(), 0, VLEN_BYTES);
    memset(tb->vs2_data.data(), 0, VLEN_BYTES);
    memset(tb->vd_data.data(), 0, VLEN_BYTES);
    memset(tb->v0_mask.data(), 0xFF, VLEN_BYTES);  // All elements active

    for (int i = 0; i < 5; i++) tick(tb, cycle);
    tb->rst_n = 1;
    tick(tb, cycle);

    // ---- Run test vectors ----
    for (int t = 0; t < num_tests; t++) {
        auto& tv = test_vectors[t];

        // Pack operands into VLEN-wide vectors
        pack_elements(tv.operand_a, SRC_W,
                      (uint32_t*)tb->vs2_data.data(), VLEN / 32);
        pack_elements(tv.operand_b, SRC_W,
                      (uint32_t*)tb->vs1_data.data(), VLEN / 32);

{% if accumulate %}
        // For accumulating instructions, pre-fill vd with zeros
        memset(tb->vd_data.data(), 0, VLEN_BYTES);
{% else %}
        memset(tb->vd_data.data(), 0, VLEN_BYTES);
{% endif %}

        // Set VL to number of source elements
        tb->vl = tv.num_src_elems;
        tb->vstart_in = 0;
        tb->vm = 1;  // Unmasked
        tb->insn = INSN_WORD;
        tb->valid_in = 1;

        tick(tb, cycle);  // Rising edge captures result into vd_out

        // Record RVFI trace (read before de-asserting valid_in)
        rvfi_csv << cycle << ","
                 << (int)tb->rvfi_valid << ","
                 << (int)tb->rvfi_trap << ","
                 << std::hex << "0x" << tb->rvfi_insn << std::dec << ","
                 << (int)tb->rvfi_rd_addr << ","
                 << std::hex << "0x" << tb->rvfi_rd_wdata << std::dec << "\n";

        // Check results
        bool test_pass = true;
        for (int e = 0; e < tv.num_dst_elems; e++) {
            uint64_t actual = extract_element(
                (const uint32_t*)tb->vd_out.data(), DST_W, e);
            uint64_t expected = tv.expected[e] & ((1ULL << DST_W) - 1);

            if (actual != expected) {
                if (test_pass) {
                    printf("FAIL [%d] %s:\n", t, tv.name);
                    test_pass = false;
                }
                printf("  elem[%d]: got 0x%lX, expected 0x%lX\n",
                       e, (unsigned long)actual, (unsigned long)expected);
            }
        }

        if (test_pass) {
            printf("PASS [%d] %s (%d output elements)\n",
                   t, tv.name, tv.num_dst_elems);
            pass_count++;
        } else {
            fail_count++;
        }

        // De-assert and advance
        tb->valid_in = 0;
        tick(tb, cycle);
    }

    // ---- Summary ----
    printf("\n=== Results: %d PASS, %d FAIL (of %d) ===\n",
           pass_count, fail_count, num_tests);

    rvfi_csv.close();
    printf("RVFI trace written to: rvfi_trace_{{ name }}.csv\n");

    tb->final();
    delete tb;

    return fail_count > 0 ? 1 : 0;
}
