// -----------------------------------------------------------------------
// Helper: pack element list into VLEN-wide bit vector
// -----------------------------------------------------------------------
static void pack_elements(const std::vector<uint64_t>& elems, int elem_bits,
                          uint32_t* out, int out_words) {
    memset(out, 0, out_words * sizeof(uint32_t));
    for (size_t i = 0; i < elems.size(); i++) {
        int bit_offset = i * elem_bits;
        int word_idx = bit_offset / 32;
        int bit_pos = bit_offset % 32;
        if (word_idx < out_words) {
            out[word_idx] |= (uint32_t)(elems[i] & ((1ULL << elem_bits) - 1)) << bit_pos;
            // Handle element spanning word boundary
            if (bit_pos + elem_bits > 32 && (word_idx + 1) < out_words) {
                out[word_idx + 1] |= (uint32_t)((elems[i] >> (32 - bit_pos)) &
                    ((1ULL << (elem_bits - (32 - bit_pos))) - 1));
            }
        }
    }
}

// -----------------------------------------------------------------------
// Helper: extract element from VLEN-wide bit vector
// -----------------------------------------------------------------------
static uint64_t extract_element(const uint32_t* data, int elem_bits, int index) {
    int bit_offset = index * elem_bits;
    int word_idx = bit_offset / 32;
    int bit_pos = bit_offset % 32;
    uint64_t val = ((uint64_t)data[word_idx] >> bit_pos);
    if (bit_pos + elem_bits > 32) {
        val |= ((uint64_t)data[word_idx + 1]) << (32 - bit_pos);
    }
    return val & ((1ULL << elem_bits) - 1);
}

