# Auto-generated by RVXV — RISC-V AI Extension Verification Platform
# Verilator build rules for: {{ name }}
# Usage:
#   make          — build and run simulation
#   make build    — build only
#   make run      — run simulation
#   make clean    — remove build artifacts

VERILATOR ?= verilator
TOP_MODULE = tb_{{ name }}
SV_FILES   = {{ name }}.sv tb_{{ name }}.sv
CPP_TB     = tb_{{ name }}.cpp
VLEN       ?= 256

# Verilator flags
VFLAGS  = --cc --exe --build
VFLAGS += --assert            # Enable SVA assertions
VFLAGS += --trace             # Enable VCD trace
VFLAGS += -Wall               # All warnings
VFLAGS += -Wno-WIDTHEXPAND -Wno-WIDTHTRUNC  # Suppress width warnings for packed ops
VFLAGS += -GVLEN=$(VLEN)      # Override VLEN parameter
VFLAGS += --top-module $(TOP_MODULE)
VFLAGS += -CFLAGS "-std=c++17 -O2"

# Build directory
OBJ_DIR = obj_dir

.PHONY: all build run clean

all: run

build: $(OBJ_DIR)/V$(TOP_MODULE)

$(OBJ_DIR)/V$(TOP_MODULE): $(SV_FILES) $(CPP_TB)
	$(VERILATOR) $(VFLAGS) $(SV_FILES) $(CPP_TB) --Mdir $(OBJ_DIR)

run: build
	./$(OBJ_DIR)/V$(TOP_MODULE)
	@echo ""
	@echo "RVFI trace: rvfi_trace_{{ name }}.csv"
	@if [ -f dump.vcd ]; then echo "VCD trace: dump.vcd"; fi

clean:
	rm -rf $(OBJ_DIR) rvfi_trace_{{ name }}.csv dump.vcd
